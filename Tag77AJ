-- INDICADOR VISUAL
local function mostrarIndicador()
    pcall(function()
        local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if pg then
            local old = pg:FindFirstChild("_77AJRecognitionIndicator")
            if old then old:Destroy() end
        end
    end)
    pcall(function()
        if gethui then
            local old = gethui():FindFirstChild("_77AJRecognitionIndicator")
            if old then old:Destroy() end
        end
    end)

    local gui = Instance.new("ScreenGui")
    gui.Name = "_77AJRecognitionIndicator"
    gui.ResetOnSpawn = false
    gui.DisplayOrder = 9999998
    pcall(function()
        if gethui then gui.Parent = gethui()
        else gui.Parent = LocalPlayer:WaitForChild("PlayerGui") end
    end)

    local frame = Instance.new("Frame", gui)
    frame.Size = UDim2.new(0, 50, 0, 28)
    frame.Position = UDim2.new(0, 10, 1, -38)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke", frame)
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Thickness = 1.5

    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, 0, 1, 0)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = "77"
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Center
end

-- QUEUE ON TELEPORT
